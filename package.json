{
  "name": "entity-keyword-control",
  "version": "1.0.0",
  "description": "ReactJS Fluent UI PCF for displaying and managing Many-to-Many keyword relationships in Dataverse",
  "scripts": {
    "build": "pcf-scripts build",
    "clean": "pcf-scripts clean",
    "lint": "pcf-scripts lint",
    "lint:fix": "pcf-scripts lint --fix",
    "rebuild": "pcf-scripts rebuild",
    "start": "pcf-scripts start",
    "start:watch": "pcf-scripts start watch",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.46.2",
    "@fluentui/react-icons": "^2.0.226"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/preset-react": "^7.24.1",
    "@babel/preset-typescript": "^7.24.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.17",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^12.1.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^16.18.98",
    "@types/powerapps-component-framework": "^1.3.18",
    "@types/react": "^17.0.50",
    "@types/react-dom": "^17.0.17",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pcf-scripts": "^1.6.3",
    "pcf-start": "^1.34.11",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "typescript": "^4.9.5"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": "babel-jest"
    },
    "moduleNameMapper": {
      "\\.(css|less|scss)$": "identity-obj-proxy"
    },
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ]
  }
}
